# -----------------------------------------------------------------------------
# Default ignores
# -----------------------------------------------------------------------------
# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# debug information files
*.dwo

# -----------------------------------------------------------------------------
# SystemVerilog / Simulation Artifacts
# -----------------------------------------------------------------------------

# Common simulator outputs
*.vvp
*.vcd
*.fst
*.lxt
*.lxt2
*.vpd
*.wlf
*.fsdb
transcript
work/

# Verilator generated C++ model/build outputs
obj_dir/
sim/
syn/*.xpr
syn/*.cache/
syn/*.runs/
syn/*.sim/
__pycache__/

# Typical Verilator-generated binaries and helper files
V*
pe_sim
verilator.log

# -----------------------------------------------------------------------------
# Vivado project-generated artifacts (do not commit)
# -----------------------------------------------------------------------------

# Common Vivado workspace temp directory
.Xil/
syn/.Xil/
syn/vivado/

# Auto-generated project outputs from opening/running in Vivado
int8-systolic-mac-array.xpr
int8-systolic-mac-array.cache/
int8-systolic-mac-array.hw/
int8-systolic-mac-array.ip_user_files/
int8-systolic-mac-array.runs/
int8-systolic-mac-array.sim/
int8-systolic-mac-array.srcs/

# Same outputs for any Vivado project name
*.xpr
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.srcs/

# Common Vivado report/database/checkpoint artifacts
*.jou
*.pb
*.rpx
*.dcp
